{
	"name": "dyni_monorepo",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"prettier": "^3.7.4",
		"turbo": "^2.9.16",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"overrides": {
		"kysely": "0.28.17"
	},
	"packageManager": "bun@1.3.14",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"biome:format": "bunx --bun @biomejs/biome check --write"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
